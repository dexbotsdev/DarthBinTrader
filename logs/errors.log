[2023-03-10 18:45:17] [ERROR] {"type":0,"tts":false,"timestamp":"2023-03-10T13:15:17.363000+00:00","referenced_message":null,"pinned":false,"nonce":"1083739852953878528","mentions":[],"mention_roles":[],"mention_everyone":false,"member":{"roles":["859867912629911632"],"premium_since":null,"pending":false,"nick":null,"mute":false,"joined_at":"2022-02-22T09:23:49.460000+00:00","flags":0,"deaf":false,"communication_disabled_until":null,"avatar":null},"id":"1083739859270778950","flags":0,"embeds":[],"edited_timestamp":null,"content":"```# Define the trend indicators\ndef populate_indicators(dataframe: DataFrame, metadata: dict) -> DataFrame:\n    dataframe['50sma'] = ta.SMA(dataframe, timeperiod=50)\n    dataframe['200sma'] = ta.SMA(dataframe, timeperiod=200)\n    dataframe['rsi'] = ta.RSI(dataframe, timeperiod=14)\n    dataframe['atr'] = ta.ATR(dataframe, timeperiod=14)\n    return dataframe\n\n# Set entry and exit rules\ndef populate_buy_trend(dataframe: DataFrame, metadata: dict) -> DataFrame:\n    conditions = (\n        (dataframe['close'] < dataframe['50sma']) &\n        (dataframe['50sma'] < dataframe['200sma']) &\n        (dataframe['rsi'] < 30) &\n        (dataframe['close'] < dataframe['50sma'] - 2*dataframe['atr'])\n    )\n    dataframe.loc[conditions, 'buy'] = 1\n    return dataframe\n\ndef populate_sell_trend(dataframe: DataFrame, metadata: dict) -> DataFrame:\n    conditions = (\n        (dataframe['close'] > dataframe['50sma']) &\n        (dataframe['50sma'] > dataframe['200sma']) &\n        (dataframe['rsi'] > 70)\n    )\n    dataframe.loc[conditions, 'sell'] = 1\n    return dataframe\n\n# Set stop-loss and take-profit rules\ndef populate_orders(\n    dataframe: DataFrame, metadata: dict, indicators: dict,\n    current_time: datetime, current_rate: float, type: str\n) -> List[Dict[str, Union[str, float]]]:\n    if type == 'buy':\n        stop_loss = current_rate + 2*indicators['atr']\n        take_profit = current_rate - 4*indicators['atr']\n    else:\n        stop_loss = current_rate - 2*indicators['atr']\n        take_profit = current_rate + 4*indicators['atr']\n    return [\n        {\n            'price': stop_loss,\n            'amount': metadata['quantity'],\n            'type': 'stop_loss',\n        },\n        {\n            'price': take_profit,\n            'amount': metadata['quantity'],\n            'type': 'take_profit',\n        },\n    ]```","components":[],"channel_id":"852593312116375642","author":{"username":"Fahmi","public_flags":0,"id":"388593569474281472","display_name":null,"discriminator":"1130","avatar_decoration":null,"avatar":"5eff6ba9491205921788af9e5d6af0e8"},"attachments":[],"guild_id":"700048804539400213"}
